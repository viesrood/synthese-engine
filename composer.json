  "type": "craft-plugin",
  "license": "MIT",
  "keywords": [
    "craft",
    "cms",
    "craftcms",
    "craft-plugin",
    "search",
    "ai",
    "vector-search",
    "embeddings",
    "rag",
    "supabase"
  ],
  "support": {
