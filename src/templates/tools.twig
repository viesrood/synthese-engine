{% extends "_layouts/cp" %}
{% set title = "Synthese Engine - Tools" %}
{% set selectedSubnavItem = "tools" %}

{% block content %}
    <div class="pane">
        <h2>Test connections</h2>
        <p class="light">Checks OpenAI (embeddings), Supabase (vector store) and Gemini (synthesis).</p>
        <button type="button" id="se-test-btn" class="btn">Test connections</button>
        <div id="se-test-result" style="margin-top:12px;"></div>
    </div>

    <div class="pane" style="margin-top:24px;">
        <h2>Reindex</h2>
        <p class="light">Queues all configured, eligible entries for (re)indexing. The queue worker must be running.</p>
        <form method="post" accept-charset="UTF-8">
            {{ csrfInput() }}
            {{ actionInput('synthese-engine/cp/reindex') }}
            {{ redirectInput('synthese-engine/tools') }}
            <button type="submit" class="btn submit">Start full reindex</button>
        </form>
    </div>

    <div class="pane" style="margin-top:24px;">
        <h2>Empty the vector store</h2>
        <p class="light">Deletes all chunks from Supabase. Only needed on a schema change or a full rebuild.</p>
        <form method="post" accept-charset="UTF-8" onsubmit="return confirm('Delete all chunks?');">
            {{ csrfInput() }}
            {{ actionInput('synthese-engine/cp/truncate') }}
            {{ redirectInput('synthese-engine/tools') }}
            <button type="submit" class="btn">Delete all chunks</button>
        </form>
    </div>

    <div class="pane" style="margin-top:24px;">
        <h2>Supabase setup SQL</h2>
        <p class="light">Generated from the current settings. Run this once in the Supabase SQL editor.</p>
        <pre style="max-height:360px;overflow:auto;">{{ sql }}</pre>
    </div>

    {% js %}
        document.getElementById('se-test-btn').addEventListener('click', function() {
            var out = document.getElementById('se-test-result');
            out.textContent = 'Working...';
            Craft.sendActionRequest('POST', 'synthese-engine/cp/test-connection')
                .then(function(r) {
                    var d = r.data;
                    function line(name, res) {
                        var ok = res && res.success;
                        return '<div>' + (ok ? '✅' : '❌') + ' ' + name + (ok ? '' : ' - ' + (res && res.error ? res.error : 'error')) + '</div>';
                    }
                    out.innerHTML = line('OpenAI', d.embedding) + line('Supabase', d.vector) + line('Gemini', d.synthesis);
                })
                .catch(function() { out.textContent = 'Test failed.'; });
        });
    {% endjs %}
{% endblock %}
