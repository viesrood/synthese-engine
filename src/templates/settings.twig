{% import "_includes/forms" as forms %}

<h2>Merk & prompt</h2>

{{ forms.textField({
    label: 'Sitenaam',
    instructions: 'Wordt genoemd in de standaard system-prompt.',
    id: 'siteName',
    name: 'siteName',
    value: settings.siteName,
}) }}

{{ forms.textareaField({
    label: 'System-prompt (optioneel)',
    instructions: 'Laat leeg voor de ingebouwde standaardprompt (met de sitenaam ingevuld).',
    id: 'systemPrompt',
    name: 'systemPrompt',
    rows: 8,
    value: settings.systemPrompt,
}) }}

{{ forms.textareaField({
    label: 'Antwoord bij onvoldoende resultaten',
    instructions: 'Getoond als de answerability-gate faalt (geen LLM-call).',
    id: 'notAnswerableMessage',
    name: 'notAnswerableMessage',
    rows: 2,
    value: settings.notAnswerableMessage,
}) }}

<hr>
<h2>Modellen & vector-store</h2>

{{ forms.textField({ label: 'Embedding-model', id: 'embeddingModel', name: 'embeddingModel', value: settings.embeddingModel }) }}
{{ forms.textField({ label: 'Embedding-dimensies', id: 'embeddingDimensions', name: 'embeddingDimensions', type: 'number', value: settings.embeddingDimensions, instructions: 'Moet overeenkomen met het model en de Supabase-kolom. Wijzigen vereist opnieuw provisionen + herindexeren.' }) }}
{{ forms.textField({ label: 'Synthese-model (Gemini)', id: 'synthesisModel', name: 'synthesisModel', value: settings.synthesisModel }) }}
{{ forms.textField({ label: 'Supabase-tabel', id: 'supabaseTable', name: 'supabaseTable', value: settings.supabaseTable }) }}
{{ forms.textField({ label: 'Supabase-RPC', id: 'matchRpc', name: 'matchRpc', value: settings.matchRpc }) }}
{{ forms.textField({ label: 'Full-text-search-taal', id: 'ftsLanguage', name: 'ftsLanguage', value: settings.ftsLanguage, instructions: "PostgreSQL-taal, bv. 'dutch' of 'english'." }) }}
{{ forms.textField({ label: 'Timezone (jaar-filter)', id: 'timezone', name: 'timezone', value: settings.timezone }) }}

<hr>
<h2>Retrieval-tuning</h2>

{{ forms.textField({ label: 'Chunk-grootte (tokens)', id: 'chunkSize', name: 'chunkSize', type: 'number', value: settings.chunkSize }) }}
{{ forms.textField({ label: 'Chunk-overlap (tokens)', id: 'chunkOverlap', name: 'chunkOverlap', type: 'number', value: settings.chunkOverlap }) }}
{{ forms.textField({ label: 'Max. kandidaat-chunks', id: 'maxChunks', name: 'maxChunks', type: 'number', value: settings.maxChunks }) }}
{{ forms.textField({ label: 'Top-K na rerank', id: 'topK', name: 'topK', type: 'number', value: settings.topK }) }}
{{ forms.textField({ label: 'Similarity-drempel', id: 'similarityThreshold', name: 'similarityThreshold', value: settings.similarityThreshold }) }}
{{ forms.textField({ label: 'Versheid-boost venster (dagen)', id: 'freshnessDays', name: 'freshnessDays', type: 'number', value: settings.freshnessDays }) }}
{{ forms.textField({ label: 'Gate: min. chunks', id: 'answerabilityMinChunks', name: 'answerabilityMinChunks', type: 'number', value: settings.answerabilityMinChunks }) }}
{{ forms.textField({ label: 'Gate: min. similarity', id: 'answerabilityMinSimilarity', name: 'answerabilityMinSimilarity', value: settings.answerabilityMinSimilarity }) }}

<hr>
<h2>Indexering & routing</h2>

{{ forms.lightswitchField({ label: 'Automatisch indexeren bij entry-save/-delete', id: 'autoIndex', name: 'autoIndex', on: settings.autoIndex }) }}
{{ forms.textField({ label: 'Route-prefix', id: 'routePrefix', name: 'routePrefix', value: settings.routePrefix, instructions: 'URL-prefix voor de publieke zoek-endpoints, bv. api/synthese.' }) }}

<hr>
<h2>Caching, rate-limiting & budget</h2>

{{ forms.textField({ label: 'Cache-duur (seconden)', id: 'cacheDuration', name: 'cacheDuration', type: 'number', value: settings.cacheDuration }) }}
{{ forms.textField({ label: 'Max. requests/minuut/IP', id: 'maxRequestsPerMinute', name: 'maxRequestsPerMinute', type: 'number', value: settings.maxRequestsPerMinute }) }}
{{ forms.textField({ label: 'Max. requests/uur/IP', id: 'maxRequestsPerHour', name: 'maxRequestsPerHour', type: 'number', value: settings.maxRequestsPerHour }) }}
{{ forms.textField({ label: 'Max. requests/dag/IP', id: 'maxRequestsPerDay', name: 'maxRequestsPerDay', type: 'number', value: settings.maxRequestsPerDay }) }}
{{ forms.textField({ label: 'Globaal max. requests/dag', id: 'maxGlobalRequestsPerDay', name: 'maxGlobalRequestsPerDay', type: 'number', value: settings.maxGlobalRequestsPerDay }) }}
{{ forms.textField({ label: 'Dagbudget (USD)', id: 'dailyBudgetUsd', name: 'dailyBudgetUsd', value: settings.dailyBudgetUsd, instructions: 'Kan via de env-var SYNTHESE_DAILY_BUDGET_USD in het config-bestand.' }) }}

<hr>
<h2>Structurele content-configuratie</h2>
<p class="light">Onderstaande instellingen bepalen <em>welke</em> content geindexeerd wordt en zijn ontwikkelaars-configuratie. Beheer ze via <code>config/synthese-engine.php</code> (ondersteunt multi-environment). Ze staan hier alleen-lezen ter controle.</p>

{% set readonlyBlocks = {
    'includeSections': settings.includeSections,
    'excludeSections': settings.excludeSections,
    'fieldConfig': settings.fieldConfig,
    'sectionContext': settings.sectionContext,
    'sectionBoosts': settings.sectionBoosts,
    'currentYearOnlySections': settings.currentYearOnlySections,
    'sourceFormatters': settings.sourceFormatters,
    'exampleQueries': settings.exampleQueries,
} %}

{% for key, value in readonlyBlocks %}
    {{ forms.field({ label: key }, '<pre style="max-height:220px;overflow:auto;margin:0;">' ~ (value|json_encode(constant('JSON_PRETTY_PRINT'))|e) ~ '</pre>') }}
{% endfor %}
